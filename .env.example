# Site Configuration
NEXT_PUBLIC_SITE_URL=https://londonlocksmith.co
NEXT_PUBLIC_SITE_NAME="London Locksmith Pro"

# Google
NEXT_PUBLIC_GOOGLE_VERIFICATION=your-google-site-verification-code
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Business Phone (for click tracking)
NEXT_PUBLIC_PHONE=02039004444
NEXT_PUBLIC_WHATSAPP=447700123456

# Analytics
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# IndexNow (Bing fast indexing) — https://www.indexnow.org/
# Generate a random key, create public/{INDEXNOW_KEY}.txt containing the key, then set it here.
INDEXNOW_KEY=your-indexnow-key
# Optional: protect the /api/indexnow POST endpoint with a bearer token
INDEXNOW_ADMIN_TOKEN=your-secret-admin-token
